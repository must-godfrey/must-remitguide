# --- Qwen Cloud (Alibaba Model Studio / DashScope, OpenAI-compatible mode) ---
QWEN_API_KEY=sk-your-key-here

# International endpoint (default). For China, use:
# https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Chat model with function-calling support
QWEN_MODEL=qwen-plus

# Embedding model (used at the RAG milestone)
QWEN_EMBED_MODEL=text-embedding-v3

# --- Server ---
# Note: 3000 is often taken; 3737 is a safe default for this demo.
PORT=3737

# --- Google sign-in (gates the live chat; /?demo stays public) ---
# Leave these blank to keep the chat open (e.g. local dev / offline demo).
# Set all three to require each user to log in with their own Google account.
# Create an OAuth 2.0 "Web application" client at https://console.cloud.google.com
#   → APIs & Services → Credentials. Add these Authorized redirect URIs:
#     http://localhost:3737/auth/google/callback        (local)
#     https://<your-app>.onrender.com/auth/google/callback   (production)
# GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxx
# SESSION_SECRET=   # a long random string — generate with: openssl rand -hex 32
# APP_BASE_URL=https://<your-app>.onrender.com   # public base URL (sets the redirect URI in prod)

# --- pgvector (added at the RAG milestone) ---
# DATABASE_URL=postgres://remit:remit@localhost:5432/remitguide
